{
    "name": "PhishMeExtension",
    "description": "Automatically take screenshots to be analyzed by a logo detector",
    "version": "1.0.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/disconnected.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    }
}
